<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.askquestion.mapper.KnowledgeBaseMapper">
    <resultMap id="KnowledgeBaseResultMap" type="com.ai.askquestion.domain.KnowledgeBase">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>
    <insert id="insert" parameterType="com.ai.askquestion.domain.KnowledgeBase" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO knowledge_base (name, description, status, created_at, updated_at)
        VALUES (#{name}, #{description}, COALESCE(#{status}, 'ACTIVE'), NOW(), NOW())
    </insert>
    <select id="findById" resultMap="KnowledgeBaseResultMap">
        SELECT * FROM knowledge_base WHERE id = #{id}
    </select>
</mapper>
